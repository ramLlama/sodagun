# mise manages Rust by setting RUSTUP_TOOLCHAIN, which overrides rust-toolchain.toml.
# Unset it so the real rustup reads rust-toolchain.toml for the toolchain version.
# Call the real rustup binary directly (not the mise shim, which doesn't support rust-toolchain.toml).
unset RUSTUP_TOOLCHAIN
PATH_add "$(dirname "$("$HOME/.cargo/bin/rustup" which rustc)")"